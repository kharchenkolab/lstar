{
  "name": "lstar-js",
  "version": "0.0.1",
  "description": "Read L* Zarr stores (v2 + v3) in the browser/Node and run viewer queries — all through the libstar C++ core compiled to WebAssembly (I/O + compute kernels), the same core that backs the lstar R and Python packages. No JS Zarr dependency.",
  "type": "module",
  "main": "core/index.ts",
  "exports": {
    ".": "./core/index.ts",
    "./wasm": "./dist/lstar_kernels.mjs",
    "./node-store": "./core/node-store.ts",
    "./http-store": "./core/http-store.ts"
  },
  "files": ["core/", "dist/", "wasm/", "build.sh"],
  "scripts": {
    "build": "bash build.sh",
    "test:kernels": "node test/kernels.test.mjs",
    "test:reader": "node --experimental-strip-types test/reader.test.ts",
    "test:reader-parallel": "node --experimental-strip-types test/reader_parallel.test.ts",
    "test:view": "node --experimental-strip-types test/view.test.ts",
    "test:writer": "node --experimental-strip-types test/writer.test.ts",
    "test:extend": "node --experimental-strip-types test/extend_primary.test.ts",
    "test:range": "node --experimental-strip-types test/range.test.ts",
    "test:consolidated": "node --experimental-strip-types test/consolidated.test.ts",
    "test:sparse": "node --experimental-strip-types test/sparse.test.ts",
    "test:compression": "node --experimental-strip-types test/compression.test.ts",
    "test:batched": "node --experimental-strip-types test/batched.test.ts"
  },
  "keywords": ["lstar", "single-cell", "zarr", "zarr-v3", "webassembly", "wasm", "viewer", "csc", "emscripten"],
  "license": "MIT",
  "dependencies": {}
}
